MACHINES = {
  :"pam" => {
              :box_name => "ubuntu/jammy64",
              :cpus => 2,
              :memory => 1024,
              :ip => "192.168.57.10",
            }
}

Vagrant.configure("2") do |config|
  config.vm.synced_folder ".", "/vagrant", disabled: true

  MACHINES.each do |boxname, boxconfig|
    config.vm.network "private_network", ip: boxconfig[:ip]
    config.vm.define boxname do |box|
      box.vm.box = boxconfig[:box_name]
      box.vm.hostname = boxname.to_s

      box.vm.provider "virtualbox" do |v|
        v.memory = boxconfig[:memory]
        v.cpus = boxconfig[:cpus]
      end
      box.vm.provision "file", source: "login.sh", destination: "/tmp/login.sh"

      box.vm.provision "shell", inline: <<-SHELL
          set -e

          # Создаём пользователя otusadm и otus
          id otusadm >/dev/null 2>&1 || useradd otusadm
          id otus >/dev/null 2>&1 || useradd otus

          # Создаём пользователям пароли
          echo "otusadm:Otus2022!" | chpasswd
          echo "otus:Otus2022!" | chpasswd

          # Создать группу admin
          groupadd admin

          # Добавляем пользователей в группу admin
          usermod -aG admin otusadm
          usermod -aG admin root

          # Проверим, что пользователи в группе admin
          grep admin /etc/group

          echo Копируем скрипт login.sh
          mv /tmp/login.sh /usr/local/bin/login.sh

          echo Добавим права на исполнение файла
          chmod +x /usr/local/bin/login.sh

          echo Подключаем pam_exec в sshd PAM, если ещё не подключён
          sed -i '/pam_exec.so.*login.sh/d' /etc/pam.d/sshd
          sed -i '/@include common-auth/i auth required pam_exec.so debug /usr/local/bin/login.sh' /etc/pam.d/sshd

          rm -f /etc/ssh/sshd_config.d/60-cloudimg-settings.conf

          tee /etc/ssh/sshd_config.d/99-local.conf > /dev/null <<'EOF'
PasswordAuthentication yes
KbdInteractiveAuthentication no
UsePAM yes
EOF
          systemctl restart ssh
          echo "ГОТОВО"
        SHELL
    end
  end
end
