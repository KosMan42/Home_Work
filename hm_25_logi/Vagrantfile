Vagrant.configure("2") do |config|

  config.vm.box = "ubuntu/jammy64"

  # ─────────────────────────────────────────
  #  Синхронизация времени (одинакова для всех машин)
  # ─────────────────────────────────────────
  $timesync = <<~SHELL
    echo ">>> Синхронизация времени"
    timedatectl set-ntp true
    timedatectl set-timezone Europe/Moscow
    timedatectl
  SHELL

  # ─────────────────────────────────────────
  #  Машина: log (192.168.56.15)
  # ─────────────────────────────────────────
  config.vm.define "log" do |log|
    log.vm.hostname = "log"
    log.vm.network "private_network", ip: "192.168.56.15"

    log.vm.provider "virtualbox" do |vb|
      vb.name   = "log"
      vb.memory = 512
      vb.cpus   = 1
    end

    log.vm.provision "shell", inline: $timesync

    log.vm.provision "shell", inline: <<~SHELL
      echo ">>> Установка rsyslog"
      apt-get update -qq
      apt-get install -y rsyslog

      echo ">>> Раскомментируем строки приёма UDP/TCP 514 в rsyslog.conf"
      sed -i 's|#module(load="imudp")|module(load="imudp")|'                     /etc/rsyslog.conf
      sed -i 's|#input(type="imudp" port="514")|input(type="imudp" port="514")|' /etc/rsyslog.conf
      sed -i 's|#module(load="imtcp")|module(load="imtcp")|'                     /etc/rsyslog.conf
      sed -i 's|#input(type="imtcp" port="514")|input(type="imtcp" port="514")|' /etc/rsyslog.conf

      echo ">>> Добавляем правила приёма логов в конец /etc/rsyslog.conf"
      mkdir -p /var/log/rsyslog
      chown -R syslog:adm /var/log/rsyslog

      cat >> /etc/rsyslog.conf << 'EOF'

$template RemoteLogs,"/var/log/rsyslog/%HOSTNAME%/%PROGRAMNAME%.log"
*.* ?RemoteLogs
& stop
EOF

      systemctl enable rsyslog
      systemctl restart rsyslog

      echo ">>> Проверка — открытые порты TCP/UDP 514"
      ss -tlnup | grep 514 || true
    SHELL
  end

  # ─────────────────────────────────────────
  #  Машина: web (192.168.56.10)
  # ─────────────────────────────────────────
  config.vm.define "web" do |web|
    web.vm.hostname = "web"
    web.vm.network "private_network", ip: "192.168.56.10"

    web.vm.provider "virtualbox" do |vb|
      vb.name   = "web"
      vb.memory = 512
      vb.cpus   = 1
    end

    web.vm.provision "shell", inline: $timesync

    web.vm.provision "shell", inline: <<~SHELL
      echo ">>> Установка nginx"
      apt-get update -qq
      apt-get install -y nginx

      echo ">>> Создаём /etc/nginx/conf.d/logging.conf с настройками логов"
      cat > /etc/nginx/conf.d/logging.conf << 'EOF'
error_log /var/log/nginx/error.log;
error_log syslog:server=192.168.56.15:514,tag=nginx_error;
access_log syslog:server=192.168.56.15:514,tag=nginx_access,severity=info combined;
EOF

      echo ">>> Проверка конфига nginx"
      nginx -t

      echo ">>> Запуск nginx"
      systemctl enable nginx
      systemctl restart nginx

      echo ">>> Тест — генерируем запрос к nginx"
      curl -s http://localhost > /dev/null && echo "nginx отвечает OK"
    SHELL
  end

end
